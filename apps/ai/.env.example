# LLM (open weights, self-hosted)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Embeddings. `auto` uses Gemini embeddings when GEMINI_API_KEY is set (semantic,
# multilingual) and otherwise falls back to the dependency-free hash embedder.
# Use `ollama` only after `ollama pull nomic-embed-text`; use `hash` to force the
# offline fallback. NOTE: switching the embedding provider changes the vector
# space — after changing it, use the admin "Clear" action and re-ingest/re-crawl
# so all stored vectors are regenerated with the new provider.
EMBED_PROVIDER=auto
EMBED_DIM=768
GEMINI_EMBED_MODEL=text-embedding-004

# Optional Gemini. If GEMINI_API_KEY is set, the AI service uses Gemini Flash.
# Leave empty to use the Ollama settings above.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Agent behaviour
AGENT_USE_WEB=1          # live web retrieval for latest info
AGENT_MAX_ITERS=1        # self-verify refinement rounds (0 = faster)
AGENT_OFFICIAL_WEB_ONLY=1
LLM_TIMEOUT=180

# Vector DB (optional — in-memory fallback if unset)
PINECONE_API_KEY=
PINECONE_INDEX=wegweiser
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Always-latest crawler
CRAWL_ON_START=0
CRAWL_INTERVAL_MIN=0
CRAWL_REGION=München
CRAWL_LANG=en
CRAWL_URLS=

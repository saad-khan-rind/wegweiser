# LLM (open weights, self-hosted)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
EMBED_MODEL=nomic-embed-text

# Optional Gemini. If GEMINI_API_KEY is set, the AI service uses Gemini Flash.
# Leave empty to use the Ollama settings above.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Agent behaviour
AGENT_USE_WEB=1          # live web retrieval for latest info
AGENT_MAX_ITERS=1        # self-verify refinement rounds (0 = faster)
LLM_TIMEOUT=180

# Vector DB (optional — in-memory fallback if unset)
PINECONE_API_KEY=
PINECONE_INDEX=wegweiser
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Always-latest crawler
CRAWL_ON_START=1
CRAWL_INTERVAL_MIN=360
CRAWL_REGION=bavaria
CRAWL_LANG=en
